    "log_settings": {
        "active": true,
        "level": "error",
        "stdout": true,
        "json": false,
        "log_payload": false
    },
    "protocol": [
        {
            "name": "SIP",
            "filter": "((tcp or sctp) and greater 42 and portrange $minport-$maxport) or (udp and greater 128 and portrange $minport-$maxport) or ip[6:2] & 0x1fff != 0 or ip6[6]=44",
            "min_port": 5060,
            "max_port": 5090,
            "protocol": [
                "udp",
                "tcp"
            ],
            "description": "Basic SIP message template"
        },
        {
            "name": "RTP",
            "filter": "(ip and portrange $minport-$maxport and ip[6] & 0x2 = 0 and ip[6:2] & 0x1fff = 0 and udp and udp[8] & 0xc0 = 0x80)",
            "min_port": 1024,
            "max_port": 65535,
            "protocol": [
                "udp"
            ],
            "description": "RTP and RTCP stream analysis template"
        },
        {
            "name": "RTCP",
            "filter": "(ip and portrange $minport-$maxport and ip[6] & 0x2 = 0 and ip[6:2] & 0x1fff = 0 and udp and udp[8] & 0xc0 = 0x80 and udp[9] >= 0xc8 && udp[9] <= 0xcc)",
            "min_port": 1024,
            "max_port": 65535,
            "protocol": [
                "udp"
            ],
            "description": "RTCP stream analysis template"
        },
        {
            "name": "HEP",
            "filter": "",
            "min_port": 9062,
            "max_port": 9063,
            "protocol": [
                "udp",
                "tcp"
            ],
            "description": "HEP message template"
        }
    ],
